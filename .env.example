# ==========================================
# 保卫前额叶 (Frontal Lobe Defender)
# AI 引擎配置 — DeepSeek API
# ==========================================
# 不配置也可正常运行，系统会自动使用离线预设回复

# DeepSeek API 地址（OpenAI 兼容协议）
VITE_AI_API_URL=https://api.deepseek.com/chat/completions

# 你的 DeepSeek API Key（在 https://platform.deepseek.com 获取）
VITE_AI_API_KEY=sk-your-deepseek-api-key-here

# 模型名称
VITE_AI_MODEL=deepseek-chat
